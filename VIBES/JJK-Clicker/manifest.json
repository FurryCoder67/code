{
  "manifest_version": 3,
  "name": "Cursed Energy Clicker — JJK",
  "version": "1.0.0",
  "description": "A Jujutsu Kaisen clicker game. Collect cursed energy, summon sorcerers, and unleash Domain Expansion!",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "storage"
  ]
}