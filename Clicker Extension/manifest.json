{
    "manifest_version": 3,
    "name": "Brainrot Clicker",
    "version": "1.0",
    "description": "Clicker game that keeps running!",
    "action": {
        "default_popup": "popup.html",
        "default_title": "Brainrot Clicker"
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "storage"
    ]
}