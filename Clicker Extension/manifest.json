{
    "manifest_version": 3,
    "name": "Brainrot Clicker",
    "version": "1.0",
    "description": "Clicker game running in the background",
    "action": {
        "default_popup": "index.html",
        "default_icon": {
            "16": "pics/extensionclicker.png",
            "48": "pics/extensionclicker.png",
            "128": "pics/extensionclicker.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "storage",
        "alarms"
    ],
    "icons": {
        "16": "pics/extensionclicker.png",
        "48": "pics/extensionclicker.png",
        "128": "pics/extensionclicker.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "pics/*.webp"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}