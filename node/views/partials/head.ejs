<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog Site | <%= title %>
    </title>
    <style>
        body {
            margin: 0;
            font-family: 'Roboto', 'Segoe UI', sans-serif;
            background-color: #0f1e13;
            color: #e0f0d9;
        }

        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: #1f3a2f;
            padding: 15px 30px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.4);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        nav .site-title h1 {
            margin: 0;
            font-size: 1.8rem;
            color: #a6f3b0;
        }

        nav .site-title p {
            margin: 0;
            font-size: 0.9rem;
            color: #c0f0a8;
            font-weight: 300;
        }

        nav ul {
            list-style: none;
            display: flex;
            gap: 20px;
            margin: 0;
            padding: 0;
        }

        nav ul li a {
            text-decoration: none;
            color: #c0f0a8;
            font-weight: 500;
            padding: 6px 12px;
            border-radius: 5px;
            transition: all 0.3s ease;
        }

        nav ul li a:hover {
            background-color: #2a6046;
            color: #fff;
        }

        .blogs.content {
            max-width: 900px;
            margin: 40px auto;
            padding: 20px;
            background-color: #1c2d20;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
        }

        .blogs h2 {
            color: #a6f3b0;
            font-size: 2rem;
            text-align: center;
            margin-bottom: 30px;
        }

        .blogs h3.title {
            font-size: 1.4rem;
            color: #d1f5b9;
            margin-bottom: 10px;
        }

        .blogs p.snippet {
            color: #e0f0d9;
            line-height: 1.6;
            margin-bottom: 20px;
        }

        footer {
            text-align: center;
            padding: 20px;
            background-color: #1f3a2f;
            color: #c0f0a8;
            margin-top: 40px;
            border-top: 1px solid #2a6046;
        }

        input[type="text"] {
            width: 300px;
            padding: 10px;
            font-size: 16px;
            font-family: Arial, sans-serif;
            color: #333;
            background-color: #f9f9f9;
            border: 2px solid #ccc;
            border-radius: 8px;
            outline: none;
            /* removes default blue focus */
            transition: border-color 0.3s;
        }

        input[type="text"]:focus {
            border-color: #007bff;
            /* blue border on focus */
        }

        input::placeholder {
            color: #aaa;
            /* lighter color for placeholder text */
        }

        textarea {
            width: 100%;
            max-width: 500px;
            height: 120px;
            padding: 12px;
            font-size: 16px;
            font-family: Arial, sans-serif;
            color: #333;
            background-color: #f0f0f0;
            border: 2px solid #ccc;
            border-radius: 10px;
            resize: vertical;
            /* allows vertical resizing only */
            outline: none;
            transition: border-color 0.3s, box-shadow 0.3s;
            height: fit-content;
        }

        textarea:focus {
            border-color: #007bff;
            box-shadow: 0 0 5px rgba(0, 123, 255, 0.5);
        }

        textarea::placeholder {
            color: #888;
        }

        button {
            padding: 10px 20px;
            font-size: 16px;
            font-family: Arial, sans-serif;
            color: white;
            background-color: #007bff;
            /* blue */
            border: none;
            border-radius: 6px;
            cursor: pointer;
            transition: background-color 0.3s, transform 0.2s;
        }

        button:hover {
            background-color: #0056b3;
            /* darker blue on hover */
            transform: scale(1.05);
            /* slight zoom effect */
        }

        button:active {
            background-color: #004494;
            /* even darker when clicked */
            transform: scale(0.98);
            /* press effect */
        }
    </style>
</head>